# xlsx-agent 設定ファイル（モデル名などをここ一箇所で切り替えられます）
# KEY=VALUE 形式。# で始まる行と空行は無視されます。
# start.sh / start.bat / アプリ本体（直接 uvicorn 起動時）すべてがこの値を使います。

# 使用する Ollama のモデル名（サーバーで `ollama list` に出る名前と一致させること）
OLLAMA_MODEL=gemma4-e4b:latest

# Ollama の API（既定で 127.0.0.1。Windowsで localhost にすると IPv6 解決で
# 10061「接続拒否」になることがあるため 127.0.0.1 を推奨）
# OLLAMA_ENDPOINT=http://127.0.0.1:11434/api/generate

# 待ち受けポート/ホスト（必要なら変更）
# PORT=8000
# HOST=0.0.0.0

# thinking(推論)モード（1で有効・精度↑/速度↓）
# XLSX_AGENT_THINK=0

# LLM応答のタイムアウト秒（CPU推論で遅い場合は増やす。既定300）
# LLM_TIMEOUT_SECONDS=300

# モデルをメモリに常駐させる時間（毎回のロードを避け高速化。-1で無期限。既定30m）
# OLLAMA_KEEP_ALIVE=30m

# エージェントの手数上限（この手数で完了できないと打ち切り。既定6）
# XLSX_AGENT_MAX_STEPS=6

# 各手の生LLM応答・実行結果をセッションの作業フォルダ内 agent.log に残す
# （何が起きて手が伸びたか後から追える。既定ON。0で無効）
# XLSX_AGENT_LOG=1
